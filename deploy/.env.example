# Copy to deploy/.env and adjust. Used by docker-compose.

# Provider: mock (offline, default) | ollama (on-prem) | openai (cloud / vLLM)
LLM_PROVIDER=mock

# On-prem Ollama (provider=ollama):
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.1

# Cloud / OpenAI-compatible (provider=openai):
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...
